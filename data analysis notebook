    "# Assign each GTA record to a time of day category\n",
    "gta_df[\"Period\"] = gta_df[\"Hour\"].apply(period_of_day)\n",
    "\n",
    "# Count motor vehicle thefts per period\n",
    "gta_by_period = gta_df.groupby(\"Period\").size().reindex([\"Morning\", \"Afternoon\", \"Evening\", \"Night\"])\n",
    "\n",
    "# Plot the distribution of GTA by period of the day\n",
    "sns.set_theme(style=\"whitegrid\")\n",
    "plt.figure(figsize=(8,5))\n",
    "ax = sns.barplot(x=gta_by_period.index, y=gta_by_period.values, palette=\"Blues_r\", edgecolor=\"black\")\n",
    "plt.title(\"Motor Vehicle Theft by Period of Day (2008–2012)\", fontsize=14)\n",
    "plt.xlabel(\"Period\")\n",
    "plt.ylabel(\"Number of Thefts\")\n",
    "\n",
    "for i, v in enumerate(gta_by_period.values):\n",
    "    ax.text(i, v + 150, f\"{v:,}\", ha=\"center\", fontsize=10, color=\"black\")\n",
    "\n",
    "plt.tight_layout()\n",
    "plt.show()\n",
    "\n"
   ]

  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "**10.1** Merge the crime and census datasets together in a suitable way."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 68,
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Shape after merge: (1861743, 36)\n",
      "   Community Area Community Area Name\n",
      "0               7        Lincoln Park\n",
      "1              37         Fuller Park\n",
      "2              29      North Lawndale\n",
      "3              64            Clearing\n",
      "4              25              Austin\n",
      "Crimes without census match: 21\n"
     ]
    }
   ],
   "source": [
    "# Copies to avoid accidentally modifying the original dataframes\n",
    "crime_df  = chicago_crime_2008_to_2012_clean_df.copy()\n",
    "census_df = chicago_census_2008_to_2012_df.copy()\n",
    "\n",
    "# Make sure both keys used for merging have the same data type. Crime:Community Area and Census:Community Area Number\n",
    "crime_df[\"Community Area\"] = crime_df[\"Community Area\"].astype(\"Int64\")\n",
    "census_df[\"Community Area Number\"] = census_df[\"Community Area Number\"].astype(\"Int64\")\n",
    "\n",
    "# drop the aggregate CHICAGO row from census data, which has NaN in community Area Number and cannot be used for area level merging\n",
    "census_df = census_df.dropna(subset=[\"Community Area Number\"])\n",
    "\n",
    "# Merge crime and census by community area number\n",
    "crime_census_df = crime_df.merge(census_df, how=\"left\", left_on=\"Community Area\", right_on=\"Community Area Number\")\n",
    "\n",
    "# clean up column name. Rename the census community area name to a simpler label and drop duplicate key column from the census side\n",
    "if \"COMMUNITY AREA NAME\" in crime_census_df.columns:\n",
    "    crime_census_df = crime_census_df.rename(\n",
    "        columns={\"COMMUNITY AREA NAME\": \"Community Area Name\"}\n",
    "    )\n",
    "\n",
    "if \"Community Area Number\" in crime_census_df.columns:\n",
    "    crime_census_df = crime_census_df.drop(columns=[\"Community Area Number\"])\n",
    "\n",
    "# quick checks\n",
    "print(\"Shape after merge:\", crime_census_df.shape)\n",
    "\n",
    "print(crime_census_df[[\"Community Area\", \"Community Area Name\"]].drop_duplicates().head())\n",
    "\n",
    "missing_census = crime_census_df[\"Community Area Name\"].isna().sum()\n",
    "print(\"Crimes without census match:\", missing_census)\n"
   ]

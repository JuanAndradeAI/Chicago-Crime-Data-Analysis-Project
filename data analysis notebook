    "def plot_crime_map(df, crime_type, weekday, dayperiod, title, zoom=10, opacity=0.4):\n",
    "\n",
    "    \"\"\"Plot an interactive map of crime incidents for a given crime type, weekday and time-of-day period.\"\"\"\n",
    "   \n",
    "    # Filter dataframe by crime type, weekday and day period\n",
    "    subset = df[\n",
    "        (df[\"Primary Type\"] == crime_type) &\n",
    "        (df[\"Weekday\"] == weekday) &\n",
    "        (df[\"DayPeriod\"] == dayperiod)\n",
    "    ].dropna(subset=[\"Latitude\", \"Longitude\"])  # ensure valid coordinates\n",
    "\n",
    "    if subset.empty:\n",
    "        print(\"No data found for this selection.\")\n",
    "        return\n",
    "    \n",
    "    # Create scatter mapbox plot\n",
    "    fig = px.scatter_mapbox(\n",
    "        subset,\n",
    "        lat=\"Latitude\",\n",
    "        lon=\"Longitude\",\n",
    "        hover_name=\"Location Description\",\n",
    "        hover_data=[\"Hour\", \"Year\"],\n",
    "        color_discrete_sequence=[\"red\"],\n",
    "        opacity=opacity,\n",
    "        zoom=zoom,\n",
    "        height=650,\n",
    "        title=title\n",
    "    )\n",
    "\n",
    "    fig.update_layout(mapbox_style=\"open-street-map\", title_x=0.5, margin=dict(l=0, r=0, t=40, b=0))\n",
    "    fig.show()\n",
    "\n",
    "plot_crime_map(\n",
    "    df=chicago_crime_2008_to_2012_clean_df,\n",
    "    crime_type=\"PROSTITUTION\",\n",
    "    weekday=\"Friday\",\n",
    "    dayperiod=\"Nighttime\",\n",
    "    title=\"Prostitution on Friday Nights – Chicago (2008–2012)\",\n",
    "    zoom=10,\n",
    "    opacity=0.45\n",
    ")\n"
   ]

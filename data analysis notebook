    "# function to classify each hour as Daytime or Nighttime\n",
    "def day_period(hour):\n",
    "    return \"Daytime\" if 6 <= hour < 18 else \"Nighttime\"\n",
    "\n",
    "# Create a new column indicating whether the crime happened during daytime or nighttime\n",
    "chicago_crime_2008_to_2012_clean_df[\"DayPeriod\"] = chicago_crime_2008_to_2012_clean_df[\"Hour\"].apply(day_period)\n",

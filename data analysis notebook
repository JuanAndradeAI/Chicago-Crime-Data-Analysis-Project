    "]\n",
    "\n",
    "socio = (crime_census_df[socio_cols].drop_duplicates(subset=\"Community Area\").set_index(\"Community Area\"))\n",
    "\n",
    "# Merge socioeconomic data with crime counts\n",
    "area_profile = socio.join(crime_counts, how=\"left\")\n",
